{
  "name": "@betterdata/scm-contracts",
  "version": "0.1.0",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/commerce-chain/scm-dcm",
    "directory": "packages/scm-contracts"
  },
  "homepage": "https://commercechain.io",
  "bugs": {
    "url": "https://github.com/commerce-chain/scm-dcm/issues"
  },
  "keywords": [
    "commerce-chain",
    "supply-chain",
    "demand-chain",
    "enterprise",
    "loop-engine",
    "governance",
    "apache-2",
    "scm",
    "contracts",
    "types",
    "schema"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean --out-dir dist",
    "prepublishOnly": "pnpm build",
    "typecheck": "node -e \"console.log('scm-contracts stub typecheck')\"",
    "lint": "node -e \"console.log('scm-contracts stub lint')\""
  }
}
