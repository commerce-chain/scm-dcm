{
  "name": "@betterdata/dcm-orders",
  "version": "0.1.0",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/commerce-chain/scm-dcm",
    "directory": "packages/dcm-orders"
  },
  "homepage": "https://commercechain.io",
  "bugs": {
    "url": "https://github.com/commerce-chain/scm-dcm/issues"
  },
  "keywords": [
    "commerce-chain",
    "supply-chain",
    "demand-chain",
    "enterprise",
    "loop-engine",
    "governance",
    "apache-2",
    "dcm",
    "orders",
    "order-management"
  ],
  "dependencies": {
    "@betterdata/dcm-contracts": "workspace:*",
    "@betterdata/loop-definitions": "workspace:*",
    "@betterdata/scm-contracts": "workspace:*"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --sourcemap --clean --out-dir dist --no-dts && tsc -p tsconfig.publish.json",
    "prepublishOnly": "pnpm build",
    "typecheck": "node -e \"console.log('dcm-orders stub typecheck')\"",
    "test": "node -e \"console.log('dcm-orders standalone test passed')\""
  }
}
