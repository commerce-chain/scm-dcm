{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://betterdata.dev/schemas/loop-events.schema.json",
  "title": "LoopEvent",
  "type": "object",
  "required": ["type", "eventId", "loopId", "aggregateId", "orgId", "occurredAt", "correlationId", "schemaVersion"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "loop.started",
        "loop.transition.requested",
        "loop.transition.executed",
        "loop.transition.blocked",
        "loop.guard.failed",
        "loop.transition.rejected",
        "loop.completed",
        "loop.error",
        "loop.spawned",
        "loop.signal.received"
      ]
    },
    "eventId": { "type": "string" },
    "loopId": { "type": "string" },
    "aggregateId": { "type": "string" },
    "orgId": { "type": "string" },
    "occurredAt": { "type": "string" },
    "correlationId": { "type": "string" },
    "causationId": { "type": "string" },
    "schemaVersion": { "const": "1.0" }
  }
}
