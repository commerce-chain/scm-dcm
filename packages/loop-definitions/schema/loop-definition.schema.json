{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://betterdata.dev/schemas/loop-definition.schema.json",
  "title": "LoopDefinition",
  "type": "object",
  "required": [
    "id",
    "version",
    "description",
    "domain",
    "states",
    "initialState",
    "terminalStates",
    "errorStates",
    "transitions",
    "outcome"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "states": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "initialState": { "type": "string", "minLength": 1 },
    "terminalStates": { "type": "array", "items": { "type": "string" } },
    "errorStates": { "type": "array", "items": { "type": "string" } },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from", "to", "allowedActors", "triggeredBy"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "allowedActors": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["human", "automation", "ai-agent", "webhook", "system"]
            },
            "minItems": 1
          },
          "triggeredBy": { "type": "string", "minLength": 1 }
        }
      }
    },
    "outcome": {
      "type": "object",
      "required": ["id", "description", "valueUnit", "measurable", "businessMetrics"],
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "valueUnit": { "type": "string" },
        "measurable": { "type": "boolean" },
        "businessMetrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "label", "unit", "improvableByAI"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "unit": { "type": "string" },
              "improvableByAI": { "type": "boolean" }
            }
          }
        }
      }
    },
    "participants": { "type": "array", "items": { "type": "string" } },
    "spawnableLoops": { "type": "array", "items": { "type": "string" } },
    "metadata": { "type": "object" }
  }
}
